# County Finder — environment variables
# Copy to .env.local and fill in values.

# ── Server ────────────────────────────────────────────────────────────────────
# Set to "production" in production deployments.
NODE_ENV=development

# ── Logging ───────────────────────────────────────────────────────────────────
# PRIVACY: Keep this OFF (false) in production to avoid logging precise coordinates.
# When true, the /api/lookup endpoint logs the resolved county name (not coordinates).
LOG_COUNTY_RESULTS=false

# ── Data ──────────────────────────────────────────────────────────────────────
# Path to the processed county data file (relative to project root).
# Default: data/counties-processed.json
# COUNTY_DATA_PATH=data/counties-processed.json
